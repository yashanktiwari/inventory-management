<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="6"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.inventory.ui.controller.AddTransactionController"
      style="-fx-padding: 25; -fx-background-color: #f4f6f8;">

    <Label fx:id="titleLabel"
           text="Issue Item"
           style="-fx-font-size: 20px; -fx-font-weight: bold;" />

    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: transparent;">

        <VBox spacing="6" style="-fx-padding:20">

            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label text="Buy / Sell:" minWidth="160" prefWidth="160"/>
                <ComboBox fx:id="buySellBox" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
            </HBox>

            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label text="Condition:" minWidth="160" prefWidth="160"/>
                <ComboBox fx:id="conditionBox" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
            </HBox>

            <VBox fx:id="sellFieldsContainer" spacing="12">
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label text="Plant:" minWidth="160" prefWidth="160"/>
                    <TextField fx:id="plantField" HBox.hgrow="ALWAYS"/>
                </HBox>
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label text="Department:" minWidth="160" prefWidth="160"/>
                    <TextField fx:id="departmentField" HBox.hgrow="ALWAYS"/>
                </HBox>
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label text="Location:" minWidth="160" prefWidth="160"/>
                    <TextField fx:id="locationField" HBox.hgrow="ALWAYS"/>
                </HBox>
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label text="Employee Code:" minWidth="160" prefWidth="160"/>
                    <TextField fx:id="employeeCodeField" HBox.hgrow="ALWAYS"/>
                </HBox>
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label text="Employee Name:" minWidth="160" prefWidth="160"/>
                    <TextField fx:id="employeeNameField" HBox.hgrow="ALWAYS"/>
                </HBox>
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label text="IP Address:" minWidth="160" prefWidth="160"/>
                    <TextField fx:id="ipField" HBox.hgrow="ALWAYS"/>
                </HBox>
            </VBox>

            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label text="Item Category:" minWidth="160" prefWidth="160"/>
                <TextField fx:id="itemCategoryField" HBox.hgrow="ALWAYS"/>
            </HBox>

            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label text="Item Code:" minWidth="160" prefWidth="160"/>
                <TextField fx:id="itemCodeField" HBox.hgrow="ALWAYS"/>
            </HBox>

            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label text="Item Name:" minWidth="160" prefWidth="160"/>
                <TextField fx:id="itemNameField" HBox.hgrow="ALWAYS"/>
            </HBox>

            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label text="Item Make:" minWidth="160" prefWidth="160"/>
                <TextField fx:id="itemMakeField" HBox.hgrow="ALWAYS"/>
            </HBox>

            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label text="Item Model:" minWidth="160" prefWidth="160"/>
                <TextField fx:id="itemModelField" HBox.hgrow="ALWAYS"/>
            </HBox>

            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label text="Item Serial:" minWidth="160" prefWidth="160"/>
                <TextField fx:id="itemSerialField" HBox.hgrow="ALWAYS"/>
            </HBox>

            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label text="Item Location:" minWidth="160" prefWidth="160"/>
                <TextField fx:id="itemLocationField" HBox.hgrow="ALWAYS"/>
            </HBox>

            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label text="Quantity:" minWidth="160" prefWidth="160"/>
                <HBox spacing="10" HBox.hgrow="ALWAYS">
                    <TextField fx:id="itemCountField" prefWidth="120"/>
                    <ComboBox fx:id="unitComboBox" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                </HBox>
            </HBox>

            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label text="Transaction Date:" minWidth="160" prefWidth="160"/>
                <HBox spacing="5" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                    <DatePicker fx:id="transactionDatePicker" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                    <Spinner fx:id="hourSpinner" prefWidth="70" minWidth="70"/>
                    <Label text=":"/>
                    <Spinner fx:id="minuteSpinner" prefWidth="70" minWidth="70"/>
                    <ComboBox fx:id="ampmBox" prefWidth="85"/>
                </HBox>
            </HBox>

            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label text="IMEI:" minWidth="160" prefWidth="160"/>
                <TextField fx:id="imeiField" HBox.hgrow="ALWAYS"/>
            </HBox>

            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label text="SIM No:" minWidth="160" prefWidth="160"/>
                <TextField fx:id="simField" HBox.hgrow="ALWAYS"/>
            </HBox>

            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label text="PO No:" minWidth="160" prefWidth="160"/>
                <TextField fx:id="poField" HBox.hgrow="ALWAYS"/>
            </HBox>

            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label text="Party Name:" minWidth="160" prefWidth="160"/>
                <TextField fx:id="partyField" HBox.hgrow="ALWAYS"/>
            </HBox>

            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label text="Status:" minWidth="160" prefWidth="160"/>
                <ComboBox fx:id="statusBox" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
            </HBox>

            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label text="Attachment:" minWidth="160" prefWidth="160"/>
                <HBox spacing="10" HBox.hgrow="ALWAYS">
                    <TextField fx:id="attachmentField" promptText="No file selected" editable="false" HBox.hgrow="ALWAYS"/>
                    <Button text="Browse" onAction="#handleBrowseAttachment"/>
                    <Button text="Clear" onAction="#handleClearAttachment"/>
                </HBox>
            </HBox>

            <HBox spacing="12" alignment="TOP_LEFT">
                <Label text="Remarks:" minWidth="160" prefWidth="160"/>
                <TextArea fx:id="remarksField" prefRowCount="3" HBox.hgrow="ALWAYS"/>
            </HBox>

        </VBox>
    </ScrollPane>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Cancel" onAction="#handleCancel"/>
        <Button fx:id="saveAndAddAnotherButton" text="Save &amp; Add Another"
                style="-fx-background-color: #1565c0; -fx-text-fill: white;" onAction="#handleSaveAndAddAnother"/>
        <Button text="Save" style="-fx-background-color: #2e7d32; -fx-text-fill: white;" onAction="#handleSave"/>
    </HBox>

</VBox>