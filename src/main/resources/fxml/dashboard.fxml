<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.inventory.ui.controller.DashboardController">

    <top>
        <VBox>
            <MenuBar>
                <Menu text="File">
                    <MenuItem fx:id="setupDatabase" text="Setup Database"
                              onAction="#handleSetupDatabase"/>
                    <SeparatorMenuItem/>
                    <MenuItem fx:id="backupDatabase" text="Backup Database"
                              onAction="#handleBackupDatabase"/>
                    <SeparatorMenuItem/>
                    <MenuItem fx:id="restoreDatabase" text="Restore Database"
                              onAction="#handleRestoreDatabase"/>
                    <SeparatorMenuItem/>
                    <MenuItem text="Exit"
                              onAction="#handleExit"/>
                </Menu>

                <Menu text="View">
                    <MenuItem fx:id="freezeColumnsMenuItem"
                              text="Freeze Columns"
                              onAction="#handleFreezeColumns"/>
                    <SeparatorMenuItem/>
                    <MenuItem fx:id="unfreezeColumnsMenuItem"
                              text="Unfreeze Columns"
                              onAction="#handleUnfreezeColumns"
                              disable="true"/>
                </Menu>

                <Menu text="Settings">
                    <MenuItem text="Change Attachment Path"
                              onAction="#handleChangeAttachmentPath"/>
                    <SeparatorMenuItem/>
                    <MenuItem fx:id="changeAdminPasswordMenuItem"
                              text="Change admin password"
                              onAction="#handleChangeAdminPassword"/>
                </Menu>

                <Menu text="About">
                    <MenuItem text="About Application"
                              onAction="#handleAbout"/>
                </Menu>
            </MenuBar>

            <Label text="Inventory Transaction History"
                   style="-fx-font-size: 20px; -fx-padding: 10;" />
        </VBox>
    </top>

    <center>
        <VBox spacing="10" style="-fx-padding: 10;"
              VBox.vgrow="ALWAYS">
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Search:"/>
                <TextField fx:id="searchField"
                           promptText="Search"
                           prefWidth="450"/>
            </HBox>
            <VBox fx:id="tableContainer" VBox.vgrow="ALWAYS" spacing="0">
                <TableView fx:id="historyTable" VBox.vgrow="ALWAYS">
                    <columnResizePolicy>
                        <TableView fx:constant="UNCONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                    <columns>

                        <TableColumn fx:id="serialColumn" text="No." prefWidth="50"/>

                        <TableColumn fx:id="buySellColumn" text="Buy / Sell" prefWidth="100"/>
                        <TableColumn fx:id="plantColumn" text="Plant" prefWidth="100"/>
                        <TableColumn fx:id="departmentColumn" text="Department" prefWidth="120"/>
                        <TableColumn fx:id="locationColumn" text="Location" prefWidth="120"/>

                        <TableColumn fx:id="employeeIdColumn" text="Emp. Code" prefWidth="120"/>
                        <TableColumn fx:id="employeeNameColumn" text="Emp. Name" prefWidth="150"/>

                        <TableColumn fx:id="ipAddressColumn" text="IP Address" prefWidth="120"/>

                        <TableColumn fx:id="itemCodeColumn" text="Item Code" prefWidth="120"/>
                        <TableColumn fx:id="itemNameColumn" text="Item Name" prefWidth="150"/>
                        <TableColumn fx:id="itemMakeColumn" text="Item Make" prefWidth="120"/>
                        <TableColumn fx:id="itemModelColumn" text="Item Model" prefWidth="120"/>
                        <TableColumn fx:id="itemSerialColumn" text="Item Serial No." prefWidth="150"/>

                        <TableColumn fx:id="itemCountColumn" text="Qty" prefWidth="90"/>
                        <TableColumn fx:id="unitColumn" text="Unit" prefWidth="80"/>

                        <TableColumn fx:id="imeiColumn" text="IMEI No." prefWidth="120"/>
                        <TableColumn fx:id="simColumn" text="SIM No." prefWidth="120"/>

                        <TableColumn fx:id="poColumn" text="PO No." prefWidth="120"/>
                        <TableColumn fx:id="partyColumn" text="Party Name" prefWidth="150"/>

                        <TableColumn fx:id="statusColumn" text="Status" prefWidth="150"/>

                        <TableColumn fx:id="issuedColumn" text="Issued Date" prefWidth="180"/>
                        <TableColumn fx:id="returnedColumn" text="Return/Scrap Date" prefWidth="180"/>

                        <TableColumn fx:id="remarksColumn" text="Remarks" prefWidth="150"/>

                        <TableColumn fx:id="actionColumn" text="Update Status" prefWidth="140"/>
                        <TableColumn fx:id="deleteColumn" text="Delete" prefWidth="100"/>

                        <TableColumn fx:id="attachmentColumn" text="Attachment" prefWidth="90"/>
                        <TableColumn fx:id="auditColumn" text="Last Modified" prefWidth="140"/>

                    </columns>
                </TableView>
            </VBox>
        </VBox>
    </center>

    <bottom>
        <HBox spacing="10" style="-fx-padding: 10;" alignment="CENTER_LEFT">

            <Button fx:id="refreshButton" text="Refresh" onAction="#handleRefresh"/>
            <Button fx:id="addTransactionButton" text="Add Transaction" onAction="#handleAddTransaction"/>
            <Button fx:id="exportExcelButton" text="Export Excel" onAction="#handleExportExcel"/>
            <Button fx:id="exportPDFButton" text="Export PDF" onAction="#handleExportPDF"/>
            <Button fx:id="resetFiltersButton" text="Reset Filters" onAction="#handleResetFilters"/>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- 🔥 Connection Indicator -->
            <HBox spacing="5" alignment="CENTER">
                <Circle fx:id="statusDot" radius="6"/>
                <Label fx:id="statusLabel" text="Checking connection..."/>
            </HBox>

            <Label text="Developed by Yashank Tiwari"
                   style="-fx-font-size: 12px; -fx-text-fill: gray;" />
        </HBox>
    </bottom>

</BorderPane>