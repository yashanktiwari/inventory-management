<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.inventory.ui.controller.ItemHistoryController">

    <top>
        <Label fx:id="titleLabel"
               style="-fx-font-size: 18px; -fx-padding: 10;" />
    </top>

    <center>
        <TableView fx:id="itemHistoryTable">

            <columns>

                <TableColumn fx:id="serialColumn" text="No." prefWidth="50"/>

                <TableColumn fx:id="buySellColumn" text="Buy/Sell" prefWidth="90"/>
                <TableColumn fx:id="plantColumn" text="Plant" prefWidth="100"/>
                <TableColumn fx:id="departmentColumn" text="Department" prefWidth="120"/>
                <TableColumn fx:id="locationColumn" text="Location" prefWidth="120"/>

                <TableColumn fx:id="employeeIdColumn" text="Employee ID" prefWidth="120"/>
                <TableColumn fx:id="employeeNameColumn" text="Employee Name" prefWidth="150"/>

                <TableColumn fx:id="ipColumn" text="IP Address" prefWidth="130"/>

                <TableColumn fx:id="itemCodeColumn" text="Item Code" prefWidth="120"/>
                <TableColumn fx:id="itemNameColumn" text="Item Name" prefWidth="150"/>
                <TableColumn fx:id="itemMakeColumn" text="Make" prefWidth="120"/>
                <TableColumn fx:id="itemModelColumn" text="Model" prefWidth="120"/>
                <TableColumn fx:id="itemSerialColumn" text="Serial No" prefWidth="130"/>
                <TableColumn fx:id="itemLocationColumn" text="Item Location" prefWidth="130"/>
                <TableColumn fx:id="itemCategoryColumn" text="Item Category" prefWidth="130"/>

                <TableColumn fx:id="itemCountColumn" text="Qty" prefWidth="90"/>
                <TableColumn fx:id="unitColumn" text="Unit" prefWidth="80"/>

                <TableColumn fx:id="imeiColumn" text="IMEI" prefWidth="130"/>
                <TableColumn fx:id="simColumn" text="SIM No" prefWidth="120"/>

                <TableColumn fx:id="poColumn" text="PO No" prefWidth="120"/>
                <TableColumn fx:id="partyColumn" text="Party Name" prefWidth="150"/>

                <TableColumn fx:id="statusColumn" text="Status" prefWidth="100"/>

                <TableColumn fx:id="issuedColumn" text="Issued Date" prefWidth="170"/>
                <TableColumn fx:id="returnedColumn" text="Returned Date" prefWidth="170"/>

                <TableColumn fx:id="remarksColumn" text="Remarks" prefWidth="200"/>
                <TableColumn fx:id="attachmentColumn" text="Attachment" prefWidth="90"/>
                <TableColumn fx:id="auditColumn" text="Last Modified" prefWidth="140"/>

            </columns>

        </TableView>
    </center>

    <bottom>
        <HBox spacing="10" style="-fx-padding: 10;">
            <Button text="Export Excel" onAction="#handleExportExcel"/>
            <Button text="Export PDF" onAction="#handleExportPDF"/>
        </HBox>
    </bottom>

</BorderPane>