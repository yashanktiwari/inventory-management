<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.inventory.ui.controller.ItemHistoryController">

    <top>
        <Label fx:id="titleLabel"
               style="-fx-font-size: 18px; -fx-padding: 10;" />
    </top>

    <center>
        <TableView fx:id="itemHistoryTable">
            <columns>
                <TableColumn fx:id="serialColumn" text="No." prefWidth="50"/>
                <TableColumn fx:id="employeeColumn" text="Employee ID" prefWidth="150"/>
                <TableColumn fx:id="personColumn" text="Person Name" prefWidth="150"/>
                <TableColumn fx:id="issuedColumn" text="Issued Date" prefWidth="180"/>
                <TableColumn fx:id="returnedColumn" text="Returned Date" prefWidth="180"/>
                <TableColumn fx:id="remarksColumn" text="Remarks" prefWidth="200"/>
            </columns>
        </TableView>
    </center>

    <bottom>
        <HBox spacing="10" style="-fx-padding: 10;">
            <Button text="Export Excel" onAction="#handleExportExcel"/>
            <Button text="Export PDF" onAction="#handleExportPDF"/>
        </HBox>
    </bottom>

</BorderPane>