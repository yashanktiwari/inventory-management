<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.inventory.ui.controller.InventoryController"
            style="-fx-background-color:#f5f7fa;">

    <!-- HEADER -->
    <top>
        <VBox spacing="15"
              style="-fx-padding:20; -fx-background-color:white; -fx-border-color:#e0e6ed; -fx-border-width:0 0 1 0;">

            <Label text="Inventory"
                   style="-fx-font-size:22px; -fx-font-weight:bold; -fx-text-fill:#2c3e50;" />

            <HBox spacing="20">

                <!-- Inventory Card -->
                <VBox spacing="5"
                      alignment="CENTER_LEFT"
                      style="-fx-background-color:white;
                             -fx-padding:15 20;
                             -fx-background-radius:10;
                             -fx-border-radius:10;
                             -fx-border-color:#e5e9f0;">

                    <Label text="📦 Items in Inventory"
                           style="-fx-text-fill:#6b7c93;" />

                    <Label fx:id="totalItemsLabel"
                           text="0"
                           style="-fx-font-size:22px;
                                  -fx-font-weight:bold;
                                  -fx-text-fill:#2c3e50;" />

                </VBox>

            </HBox>

        </VBox>
    </top>


    <!-- TABLE AREA -->
    <center>

        <VBox spacing="10" style="-fx-padding:30 25 25 25;">

            <TableView fx:id="inventoryTable"
                       VBox.vgrow="ALWAYS"
                       style="-fx-background-radius:10;
                              -fx-border-radius:10;
                              -fx-border-color:#dfe6ee;">

                <columns>

                    <TableColumn fx:id="itemNameCol"
                                 text="Item Name"
                                 prefWidth="420" />

                    <TableColumn fx:id="stockCol"
                                 text="Quantity"
                                 prefWidth="200" />

                </columns>

            </TableView>

        </VBox>

    </center>

</BorderPane>